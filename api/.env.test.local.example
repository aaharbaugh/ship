# Ship API - Local Test Database Configuration
#
# Copy this to .env.test.local when you want Vitest to use a database
# that is separate from your seeded benchmark/dev database.
#
#   cp api/.env.test.local.example api/.env.test.local
#
# Then create the test database once:
#   psql postgresql://ship:ship_dev_password@localhost:5433/postgres -c "CREATE DATABASE ship_test;"
#
# Recommended split:
# - .env.local keeps DATABASE_URL for your seeded benchmark/dev DB
# - .env.test.local points TEST_DATABASE_URL at the disposable test DB

TEST_DATABASE_URL=postgresql://ship:ship_dev_password@localhost:5433/ship_test
